# DeepFind — .gitignore

# ───────────────────────────────────────────
# Python / Engine
# ───────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
wheels/
*.whl
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
.env
.env.local
.env.development
.env.production

# ───────────────────────────────────────────
# Node / Electron / React
# ───────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
dist-electron/
out/
.output/
*.local

# ───────────────────────────────────────────
# DeepFind Local Data (never commit user data)
# ───────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.faiss
*.index
data/
local_data/
engine/data/

# ───────────────────────────────────────────
# IDE / Editor
# ───────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ───────────────────────────────────────────
# Logs
# ───────────────────────────────────────────
logs/
*.log
*.log.*

# ───────────────────────────────────────────
# OS
# ───────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ───────────────────────────────────────────
# Packaging / Release
# ───────────────────────────────────────────
release/
*.exe
*.dmg
*.AppImage
*.deb
*.rpm
*.snap
*.zip
*.tar.gz

# ───────────────────────────────────────────
# Test artifacts
# ───────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/
tests/fixtures/real_files/

# ───────────────────────────────────────────
# Sentence Transformers / AI model cache
# ───────────────────────────────────────────
.cache/
engine/ai/models/
models/
*.onnx
*.pt
*.bin

# ───────────────────────────────────────────
# Misc
# ───────────────────────────────────────────
*.bak
*.tmp
*.temp
.secrets
